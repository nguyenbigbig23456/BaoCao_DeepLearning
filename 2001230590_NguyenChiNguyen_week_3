        "app = Flask(__name__)\n",
        "\n",
        "# Tải mô hình đã lưu\n",
        "model = load_model('car_model.h5')\n",
        "\n",
        "# Render trang chủ\n",
        "@app.route('/')\n",
        "def home():\n",
        "    # Cần tạo file index.html trong thư mục templates\n",
        "    return render_template('index.html')\n",
        "\n",
        "# Xử lý khi người dùng submit form\n",
        "@app.route('/predict', methods=['POST'])\n",
        "def predict():\n",
        "    # Lấy dữ liệu từ form HTML\n",
        "    int_features = [int(x) for x in request.form.values()]\n",
        "    final_features = [np.array(int_features)]\n",
        "\n",
        "    # Dự đoán\n",
        "    prediction = model.predict(final_features)\n",
        "    predicted_class = np.argmax(prediction[0])\n",
        "\n",
        "    # Map kết quả về dạng text (tùy thuộc vào LabelEncoder ở bài 5)\n",
        "    class_names = ['unacc', 'acc', 'good', 'vgood']\n",
        "    result = class_names[predicted_class]\n",
        "\n",
        "    return render_template('index.html', prediction_text='Dự đoán chất lượng xe: {}'.format(result))\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    app.run(debug=True)"
