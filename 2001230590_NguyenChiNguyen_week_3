      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "from keras.models import Sequential\n",
        "from keras.layers import Dense, Activation, Input\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# 1. Tải dữ liệu\n",
        "url = \"https://raw.githubusercontent.com/mwaskom/seaborn-data/master/car_crashes.csv\"\n",
        "data = pd.read_csv(url)\n",
        "\n",
        "# 2. Chọn Predictors và Target phù hợp\n",
        "Predictors = ['speeding', 'alcohol', 'not_distracted', 'no_previous', 'ins_premium', 'ins_losses']\n",
        "TargetVariable = ['total']\n",
        "\n",
        "X = data[Predictors].values\n",
        "y = data[TargetVariable].values\n",
        "\n",
        "# 3. Chuẩn hóa dữ liệu\n",
        "PredictorScaler = StandardScaler()\n",
        "TargetVarScaler = StandardScaler()\n",
        "\n",
        "X = PredictorScaler.fit_transform(X)\n",
        "y = TargetVarScaler.fit_transform(y)\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
        "\n",
        "# 4. Xây dựng mô hình\n",
        "model = Sequential([\n",
        "    Input(shape=(6,)),\n",
        "    Dense(10, kernel_initializer='normal', activation='relu'),\n",
        "    Dense(5, kernel_initializer='normal', activation='relu'),\n",
        "    Dense(1, kernel_initializer='normal', activation='linear')\n",
        "])\n",
        "\n",
        "model.compile(loss='mean_squared_error', optimizer='adam')\n",
        "\n",
        "# 5. Huấn luyện mô hình\n",
        "print(\"Đang huấn luyện mô hình...\")\n",
        "history = model.fit(X_train, y_train, epochs=100, batch_size=10, verbose=0)\n",
        "\n",
        "# 6. Dự đoán\n",
        "predicted_total = model.predict(X_test)\n",
        "predicted_total = TargetVarScaler.inverse_transform(predicted_total)\n",
        "y_test_orig = TargetVarScaler.inverse_transform(y_test)\n",
        "\n",
        "# 7. Hiển thị kết quả và Biểu đồ\n",
        "plt.figure(figsize=(10,6))\n",
        "plt.plot(y_test_orig, label='Thực tế (Actual)', color='blue', marker='o')\n",
        "plt.plot(predicted_total, label='Dự đoán (Predicted)', color='red', linestyle='--', marker='x')\n",
        "plt.title('So sánh giá trị Thực tế và Dự đoán')\n",
        "plt.ylabel('Total Crashes')\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "TestData = pd.DataFrame(data=y_test_orig, columns=['Total_Actual'])\n",
        "TestData['Total_Predicted'] = predicted_total\n",
        "display(TestData.head())"
      ],
